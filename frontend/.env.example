# =============================================================================
# DocCraft — Frontend (Next.js)
# Copie para: frontend/.env.local
# =============================================================================
#
# O Next.js usa estas variáveis no servidor (rotas /api/*) e no browser
# (apenas as que começam com NEXT_PUBLIC_*).
#
# Obrigatórias para exportar PDF com upload no Supabase + salvar em `documents`:
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY  (recomendada; sem ela o upload costuma falhar por RLS)
#
# Obrigatória para login/cadastro (Auth.js / NextAuth):
#   AUTH_SECRET  (gere com: openssl rand -base64 32)
#
# Opcionais:
#   AUTH_URL — URL pública do app em produção (ex.: https://seu-dominio.com)
#   GITHUB_TOKEN — importar README sem bater no rate limit da API do GitHub
#   WORKER_URL — legado (não é necessário no fluxo Next + Supabase)
#
# Login com GitHub (OAuth App em https://github.com/settings/developers):
#   AUTH_GITHUB_ID e AUTH_GITHUB_SECRET — callback: {AUTH_URL}/api/auth/callback/github
#
# Tradução de README (rota /api/translate-markdown):
#   OPENAI_API_KEY — opcional; sem ela, "Traduzir e abrir" retorna erro de configuração
# =============================================================================

# --- Auth.js / NextAuth (login + sessão) -------------------------------------
AUTH_SECRET=
# AUTH_URL=https://localhost:3000

# GitHub OAuth (escopo repo + read:user é solicitado no código)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# OpenAI — tradução de Markdown na página /repos
# OPENAI_TRANSLATE_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# --- Supabase (Project Settings → API em https://app.supabase.com) ----------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave service_role: use SÓ no servidor (nunca commitar, nunca expor no client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Worker de PDF (legado / opcional) ---------------------------------------
# WORKER_URL=http://localhost:4000

# --- GitHub (import README) --------------------------------------------------
# Token clássico ou fine-grained; escopos mínimos para ler repos públicos
GITHUB_TOKEN=
