# =============================================================================
# DocCraft — Worker (PDF)
# Copie para: backend/worker/.env
# =============================================================================
#
# Este serviço NÃO usa Supabase. Só gera PDF a partir de HTML.
#
# Fluxo: Next chama POST /generate com { html, template } → retorna bytes PDF.
#
# Estratégia de geração:
#   1. Se ENABLE_LATEX não for "false" e existir `pdflatex` no PATH → LaTeX
#   2. Senão → Puppeteer (precisa: npm install puppeteer no workspace do worker)
#   3. Se ambos falharem, a API Next devolve fallback (HTML / base64)
# =============================================================================

PORT=4000

# "false" = pular LaTeX e ir direto para Puppeteer
ENABLE_LATEX=true
